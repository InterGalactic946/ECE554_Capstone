module Clock_Gen (

    //////////// ADC //////////
    output ADC_CONVST,
    output ADC_DIN,
    input  ADC_DOUT,
    output ADC_SCLK,

    //////////// CLOCK //////////
    input CLOCK2_50,
    input CLOCK3_50,
    input CLOCK4_50,
    input CLOCK_50,

    //////////// SEG7 //////////
    output reg [6:0] HEX0,
    output reg [6:0] HEX1,
    output reg [6:0] HEX2,
    output reg [6:0] HEX3,
    output reg [6:0] HEX4,
    output reg [6:0] HEX5,

    //////////// KEY //////////
    input [3:0] KEY,

    //////////// SW //////////
    input [9:0] SW,

    //////////// GPIO_0, GPIO_0 connect to GPIO Default //////////
    inout [35:0] GPIO
);

  // Declare intermediate signals as type wire/reg.
  wire rst;
  reg volt_on;
  wire [1:0] curr_mode;
  wire [11:0] volt_lvl;

  // Active high synchronous reset.
  assign rst = ~KEY[0];

  // We don't care about the remaining GPIO pins.
  assign GPIO[35:3] = 33'hz_zzzz_zzzz;

  // Instantiate ADC Controller.
  ADC_Controller iADC_CTRL (
      .CLOCK(CLOCK_50),
      .RESET(rst),
      .ADC_SCLK(ADC_SCLK),
      .ADC_CS_N(ADC_CONVST),
      .ADC_DOUT(ADC_DOUT),
      .ADC_DIN(ADC_DIN),
      .CH0(volt_lvl),
      .CH1(),
      .CH2(),
      .CH3(),
      .CH4(),
      .CH5(),
      .CH6(),
      .CH7()
  );

  // Latch when voltage is on and off to prevent glitches in the clock output.
  always @(posedge CLOCK_50) begin
    if (rst) volt_on <= 1'b0;
    else if (volt_lvl < 12'd1320)  // Turn off slightly below 1.62V
      volt_on <= 1'b0;
    else if (volt_lvl > 12'd1330)  // Turn on slightly above 1.62V
      volt_on <= 1'b1;
  end

  // Instantiate Clock Generator.
  Mic_Clk_Gen iCLK_GEN (
      .clk_i(CLOCK_50),
      .rst_i(rst),
      .volt_on_i(volt_on),
      .mode_req_i(SW[1:0]),

      .data_val_o (GPIO[1]),
      .curr_mode_o(curr_mode),
      .mic_clk_o  (GPIO[0])
  );

  // We pass the 4-bit "nibbles" directly to the decoder
  Seven_Seg s2 (
      .bin(volt_lvl[3:0]),
      .hex(HEX2)
  );  // Low nibble
  Seven_Seg s3 (
      .bin(volt_lvl[7:4]),
      .hex(HEX3)
  );  // Mid nibble
  Seven_Seg s4 (
      .bin(volt_lvl[11:8]),
      .hex(HEX4)
  );  // High nibble

  // 2. Turn off HEX5 since we only have 12 bits of data
  assign HEX5 = 7'b1111111;

  // 3. Drive Mode (HEX0) and Status (HEX1) manually
  always @(*) begin
    // HEX 1: Status (U for Upper, L for Lower)
    if (volt_on) HEX1 = 7'b1000001;
    else HEX1 = 7'b1000111;

    // HEX 0: Mode (0, 1, 2, or 3)
    case (curr_mode)
      2'b00:   HEX0 = 7'b1000000;  // 0
      2'b01:   HEX0 = 7'b1111001;  // 1
      2'b10:   HEX0 = 7'b0100100;  // 2
      2'b11:   HEX0 = 7'b0110000;  // 3
      default: HEX0 = 7'b1111111;
    endcase
  end
