     <name>gmacgrp_MAC_Address112_Low</name>
     <description>The MAC Address112 Low register holds the lower 32 bits of the 113th 6-byte MAC address of the station.
Note that all MAC Address Low registers (except MAC Address0 Low) have the same format.</description>
     <addressOffset>0xb04</addressOffset>
     <size>32</size>
     <access>read-write</access>
     <resetValue>0xffffffff</resetValue>
     <resetMask>0xffffffff</resetMask>
     <fields>
      <field>
       <name>addrlo</name>
       <description>This field contains the lower 32 bits of the 113th 6-byte MAC address. The content of this field is undefined until loaded by software after the initialization process.</description>
