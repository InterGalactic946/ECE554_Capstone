     <name>gmacgrp_MAC_Address52_Low</name>
     <description>The MAC Address52 Low register holds the lower 32 bits of the 53th 6-byte MAC address of the station.
Note that all MAC Address Low registers (except MAC Address0 Low) have the same format.</description>
     <addressOffset>0x924</addressOffset>
     <size>32</size>
     <access>read-write</access>
     <resetValue>0xffffffff</resetValue>
     <resetMask>0xffffffff</resetMask>
