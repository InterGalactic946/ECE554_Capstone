       <access>read-only</access>
      </field>
     </fields>
    </register>
    <register>
     <name>gmacgrp_rxtcperroctets</name>
     <description>Number of bytes received in a TCP segment with checksum errors</description>
     <addressOffset>0x27c</addressOffset>
