     <access>read-only</access>
     <resetValue>0x0</resetValue>
     <resetMask>0xffffffff</resetMask>
     <fields>
      <field>
       <name>cnt</name>
       <description>Number of bytes received in a good TCP segment</description>
       <lsb>0</lsb>
