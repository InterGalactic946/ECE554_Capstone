       <msb>31</msb>
       <access>read-write</access>
      </field>
     </fields>
    </register>
    <register>
     <name>gmacgrp_MAC_Address113_High</name>
     <description>The MAC Address113 High register holds the upper 16 bits of the 114th 6-byte MAC address of the station. Because the MAC address registers are configured to be double-synchronized to the (G)MII clock domains, the synchronization is triggered only when bits[31:24] (in little-endian mode) or Bits[7:0] (in big-endian mode) of the MAC Address113 Low Register are written. For proper synchronization updates, the consecutive writes to this Address Low Register should be performed after at least four clock cycles in the destination clock domain.
Note that all MAC Address High registers (except MAC Address0 High) have the same format.</description>
     <addressOffset>0xb08</addressOffset>
     <size>32</size>
