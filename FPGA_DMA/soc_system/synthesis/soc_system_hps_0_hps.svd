     <resetMask>0xffffffff</resetMask>
     <fields>
      <field>
       <name>cnt</name>
       <description>Number of bytes received in a UDP segment that had checksum errors</description>
       <lsb>0</lsb>
       <msb>31</msb>
       <access>read-only</access>
      </field>
